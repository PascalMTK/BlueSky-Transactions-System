{
  "version": 2,
  "framework": null,
  "buildCommand": "cd bluesky-transactions && composer install --no-dev --optimize-autoloader",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.2",
      "includeFiles": "bluesky-transactions/**"
    }
  },
  "routes": [
    {
      "src": "/favicon.ico",
      "dest": "/bluesky-transactions/public/favicon.ico"
    },
    {
      "src": "/robots.txt",
      "dest": "/bluesky-transactions/public/robots.txt"
    },
    {
      "src": "/(css|js|images)/(.*)",
      "dest": "/bluesky-transactions/public/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
