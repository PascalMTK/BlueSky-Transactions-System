{
  "version": 2,
  "framework": null,
  "buildCommand": "curl -sS https://getcomposer.org/installer | php -- --install-dir=/tmp --filename=composer && /tmp/composer install --no-dev --optimize-autoloader --working-dir=./bluesky-transactions",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.2",
      "includeFiles": "bluesky-transactions/**"
    }
  },
  "routes": [
    {
      "src": "/favicon.ico",
      "dest": "/bluesky-transactions/public/favicon.ico"
    },
    {
      "src": "/robots.txt",
      "dest": "/bluesky-transactions/public/robots.txt"
    },
    {
      "src": "/(css|js|images)/(.*)",
      "dest": "/bluesky-transactions/public/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
