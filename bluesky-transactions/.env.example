APP_NAME="BLUESKY Transactions"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.vercel.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=your-database-host
DB_PORT=3306
DB_DATABASE=bluesky_transactions
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password

# Use cookie sessions (Vercel filesystem is read-only)
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# Use array cache (no file system writes on Vercel)
CACHE_STORE=array

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@bluesky.com"
MAIL_FROM_NAME="${APP_NAME}"
