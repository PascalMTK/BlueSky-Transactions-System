# ─────────────────────────────────────────────────────────────────────────────
# VERCEL DEPLOYMENT — set ALL of these as Environment Variables in the Vercel
# project dashboard (Settings → Environment Variables).
# Generate APP_KEY locally: php artisan key:generate --show
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME="BLUESKY Transactions"
APP_ENV=production
APP_KEY=base64:CHANGE_ME_run_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://your-app.vercel.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_LEVEL=error

# ── Database (use a remote MySQL/PlanetScale/Neon host — not localhost) ───────
DB_CONNECTION=mysql
DB_HOST=your-database-host
DB_PORT=3306
DB_DATABASE=bluesky_transactions
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password

# ── Sessions & Cache (Vercel filesystem is read-only) ────────────────────────
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=array

# ── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@bluesky.com"
MAIL_FROM_NAME="${APP_NAME}"
